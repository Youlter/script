local function ApplyChams(Player)
    local function UpdateChams()
        if Player.Character then
            local Highlight = Player.Character:FindFirstChild("SuiteChams")
            if not Highlight then
                Highlight = Instance.new("Highlight")
                Highlight.Name = "SuiteChams"
                Highlight.Parent = Player.Character
            end
            
            local IsTeammate = getgenv().SuiteConfig.Visuals.TeamCheck and Player.Team == LP.Team
            Highlight.Enabled = getgenv().SuiteConfig.Visuals.Chams and not IsTeammate
            Highlight.FillColor = getgenv().SuiteConfig.Visuals.ChamsColor
            Highlight.FillTransparency = getgenv().SuiteConfig.Visuals.ChamsTransparency
            Highlight.OutlineTransparency = 0 -- Всегда четкая обводка
            Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        end
    end
    
    Player.CharacterAdded:Connect(function() task.wait(0.5); UpdateChams() end)
    UpdateChams()
end

