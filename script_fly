-- // [LOGIC] Tween Teleport (Плавный телепорт для обхода проверок)
local function TweenTP(TargetCFrame)
    if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        local Distance = (LP.Character.HumanoidRootPart.Position - TargetCFrame.p).Magnitude
        local Time = Distance / getgenv().SuiteConfig.Teleport.TweenSpeed
        
        local Tween = game:GetService("TweenService"):Create(
            LP.Character.HumanoidRootPart,
            TweenInfo.new(Time, Enum.EasingStyle.Linear),
            {CFrame = TargetCFrame}
        )
        Tween:Play()
        return Tween
    end
end

