-- Item ESP Logic
local ItemHighlights = {}

local function HighlightItem(item)
    if item:IsA("BackpackItem") or (item:IsA("Part") and item:FindFirstChildOfClass("TouchTransmitter")) then
        local Highlight = Instance.new("Highlight")
        Highlight.Name = "ItemHighlight"
        Highlight.FillColor = getgenv().SuiteConfig.Inventory.ItemColor
        Highlight.OutlineColor = Color3.new(1, 1, 1)
        Highlight.Parent = item
        table.insert(ItemHighlights, Highlight)
    end
end

RunService.Heartbeat:Connect(function()
    if getgenv().SuiteConfig.Inventory.ItemESP then
        for _, v in pairs(workspace:GetChildren()) do
            if v:IsA("Tool") or v:IsA("Handle") then
                if not v:FindFirstChild("ItemHighlight") then
                    HighlightItem(v)
                end
            end
        end
    else
        for _, v in pairs(ItemHighlights) do
            if v then v:Destroy() end
        end
        ItemHighlights = {}
    end
end)

