function SecuritySystem:ToggleAntiKick(state)
    self.AntiKick = state
    if state and not self.OriginalKick then
        self.OriginalKick = LocalPlayer.Kick
        LocalPlayer.Kick = function(...)
            if not self.AntiKick then
                return self.OriginalKick(...)
            end
            AnnouncementSystem:Add("Blocked kick attempt!", 2)
            return nil
        end
    elseif not state and self.OriginalKick then
        LocalPlayer.Kick = self.OriginalKick
        self.OriginalKick = nil
    end
end

