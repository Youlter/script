local AnnouncementSystem = {
    Queue = {},
    Active = false
}

function AnnouncementSystem:Add(message, duration)
    table.insert(self.Queue, {Text = message, Time = duration or 3})
    if not self.Active then
        self:Process()
    end
end

function AnnouncementSystem:Process()
    if #self.Queue == 0 then
        self.Active = false
        return
    end
    self.Active = true
    local announce = table.remove(self.Queue, 1)
    Services.StarterGui:SetCore("SendNotification", {
        Title = "Youlter System",
        Text = announce.Text,
        Duration = announce.Time
    })
    task.wait(announce.Time + 0.5)
    self:Process()
end

local WatermarkSystem = {
    Enabled = false,
    TextObject = nil,
    UpdateInterval = nil
}

function WatermarkSystem:Toggle(state)
    self.Enabled = state
    if state then
        if not self.TextObject then
            self.TextObject = Drawing.new("Text")
            self.TextObject.Size = 14
            self.TextObject.Color = Color3.fromRGB(255,255,255)
            self.TextObject.Center = false
            self.TextObject.Position = Vector2.new(10, 10)
            self.TextObject.Transparency = 1
        end
        self.UpdateInterval = Services.RunService.RenderStepped:Connect(function()
            if self.Enabled then
                local fps = math.floor(1 / Services.RunService.Heartbeat:Wait())
                local memory = math.floor(collectgarbage("count"))
                self.TextObject.Text = string.format("Youlter Ultra | FPS: %d | Mem: %d MB | Players: %d", 
                    fps, memory, #Services.Players:GetPlayers())
                self.TextObject.Visible = true
