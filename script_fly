local function GetClosestPlayer()
    local Target = nil
    local MaxDist = getgenv().SuiteConfig.Combat.FOV
    
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LP and v.Character and v.Character:FindFirstChild(getgenv().SuiteConfig.Combat.TargetPart) and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
            local Part = v.Character[getgenv().SuiteConfig.Combat.TargetPart]
            local Pos, OnScreen = Camera:WorldToViewportPoint(Part.Position)
            
            if OnScreen then
                local MouseDist = (Vector2.new(Pos.X, Pos.Y) - UIS:GetMouseLocation()).Magnitude
                if MouseDist < MaxDist then
                    if getgenv().SuiteConfig.Combat.WallCheck then
                        local RayParams = RaycastParams.new()
                        RayParams.FilterType = Enum.RaycastFilterType.Exclude
                        RayParams.FilterDescendantsInstances = {LP.Character, Camera}
                        
                        local Result = workspace:Raycast(Camera.CFrame.Position, (Part.Position - Camera.CFrame.Position).Unit * 500, RayParams)
                        if Result and Result.Instance:IsDescendantOf(v.Character) then
                            MaxDist = MouseDist
                            Target = v
                        end
                    else
                        MaxDist = MouseDist
                        Target = v
                    end
                end
            end
        end
    end
    return Target
end

