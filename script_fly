-- // [LOGIC] Chat Keyword Monitor
local function CheckMessage(player, msg)
    if getgenv().SuiteConfig.Logs.ChatKeywords then
        local lowerMsg = msg:lower()
        for _, keyword in pairs(getgenv().SuiteConfig.Logs.Keywords) do
            if lowerMsg:find(keyword) then
                Rayfield:Notify({
                    Title = "🚨 Keyword Detected!",
                    Content = player.Name .. ": " .. msg,
                    Duration = 10
                })
                PlayAlertSound()
                break
            end
        end
    end
end

