    Particles = {}
}

function ParticleSystem:CreateTrail()
    if not self.Enabled or not ValidateCharacter() then return end
    local particle = Instance.new("Part")
    particle.Size = Vector3.new(0.5, 0.5, 0.5)
    particle.BrickColor = BrickColor.new("Bright red")
    particle.Material = Enum.Material.Neon
    particle.CanCollide = false
    particle.Anchored = true
    particle.CFrame = PlayerData.RootPart.CFrame
    particle.Parent = Services.Workspace
    table.insert(self.Particles, particle)
    task.wait(0.05)
    for i, p in pairs(self.Particles) do
        if i < #self.Particles - 50 then
            p:Destroy()
            table.remove(self.Particles, i)
        end
    end
end

local function ExtraMovementFeatures()
    if not ValidateCharacter() then return end
    local moveDir = PlayerData.Humanoid.MoveDirection
    if moveDir.Magnitude > 0 then
        if _G.Settings.Movement.SpeedBoost then
            PlayerData.Humanoid.WalkSpeed = _G.Settings.Movement.WalkSpeed + _G.Settings.Movement.SpeedBoostValue
        end
        if _G.Settings.Movement.StrafeBoost then
            local vel = PlayerData.RootPart.Velocity
            local newVel = vel + (moveDir * _G.Settings.Movement.StrafeValue)
            PlayerData.RootPart.Velocity = newVel
        end
    end
end

local function SlipperySlides()
    if not _G.Settings.Movement.Slides or not ValidateCharacter() then return end
    if PlayerData.Humanoid.FloorMaterial ~= Enum.Material.Air and PlayerData.Humanoid.MoveDirection.Magnitude > 0 then
        PlayerData.Humanoid.WalkSpeed = _G.Settings.Movement.SlideSpeed
        local vel = PlayerData.RootPart.Velocity
        PlayerData.RootPart.Velocity = Vector3.new(vel.X * 1.05, vel.Y, vel.Z * 1.05)
    end
end

local function DashAbility()
    if not _G.Settings.Movement.Dash.Active then return end
    local dashKey = _G.Settings.Movement.Dash.Key or Enum.KeyCode.Q
    if Services.UserInputService:IsKeyDown(dashKey) and tick() - (_G.Settings.Movement.Dash.LastDash or 0) > _G.Settings.Movement.Dash.Cooldown then
        _G.Settings.Movement.Dash.LastDash = tick()
        local direction = Camera.CFrame.LookVector * _G.Settings.Movement.Dash.Distance
        PlayerData.RootPart.Velocity = direction
        AnnouncementSystem:Add("Dashed!", 1)
    end
end

local function EdgeDetect()
    if not _G.Settings.Movement.EdgeDetect or not ValidateCharacter() then return end
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {PlayerData.Character}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    local ray = Services.Workspace:Raycast(PlayerData.RootPart.Position, Vector3.new(0, -5, 0), raycastParams)
    if not ray then
        PlayerData.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end

