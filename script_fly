local DiscordWebhookSystem = {
    Enabled = false,
    WebhookURL = "",
    Queue = {},
    Sending = false
}

function DiscordWebhookSystem:SetWebhook(url)
    self.WebhookURL = url
end

function DiscordWebhookSystem:SendMessage(content, title, color)
    if not self.Enabled or self.WebhookURL == "" then return end
    table.insert(self.Queue, {Content = content, Title = title or "Youlter Log", Color = color or 3092790})
    if not self.Sending then
        self:Sender()
    end
end

function DiscordWebhookSystem:Sender()
    if #self.Queue == 0 then
        self.Sending = false
        return
    end
    self.Sending = true
    local data = table.remove(self.Queue, 1)
    local payload = {
        embeds = {{
            title = data.Title,
            description = data.Content,
            color = data.Color,
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
            footer = {text = "Youlter Ultra System v" .. _G.Version}
        }}
    }
    local encoded = game:GetService("HttpService"):JSONEncode(payload)
    local headers = {["Content-Type"] = "application/json"}
    pcall(function()
        request({Url = self.WebhookURL, Method = "POST", Headers = headers, Body = encoded})
    end)
    task.wait(1)
    self:Sender()
end

local AutoFarmSystem = {
    Enabled = false,
    TargetPart = nil,
    FarmRadius = 50,
    FarmDelay = 0.5,
    CollectedItems = 0,
    Blacklist = {}
}

function AutoFarmSystem:SetTarget(partName)
    self.TargetPart = partName
end

function AutoFarmSystem:Start()
    self.Enabled = true
    self.CollectedItems = 0
    task.spawn(function()
        while self.Enabled and ValidateCharacter() do
            local parts = Services.Workspace:GetDescendants()
            local closest = nil
            local shortestDist = self.FarmRadius
            for _, part in pairs(parts) do
                if part.Name == self.TargetPart and part:IsA("BasePart") and not table.find(self.Blacklist, part) then
                    local dist = (part.Position - PlayerData.RootPart.Position).Magnitude
                    if dist < shortestDist then
                        shortestDist = dist
                        closest = part
                    end
                end
            end
            if closest then
                PlayerData.Humanoid:MoveTo(closest.Position)
                if shortestDist < 5 then
                    task.wait(self.FarmDelay)
                    if closest.Parent then
                        self.CollectedItems = self.CollectedItems + 1
                        table.insert(self.Blacklist, closest)
