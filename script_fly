local function CreateTracer()
    local line = Drawing.new("Line")
    line.Visible = false
    line.Color = Color3.fromRGB(255, 255, 255)
    line.Thickness = 1
    line.Transparency = 1
    return line
end

local tracers = {}

RunService.RenderStepped:Connect(function()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LP and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = player.Character.HumanoidRootPart
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            
            -- Логика Трейсеров
            if getgenv().SuiteConfig.Visuals.Tracers and onScreen then
                if not tracers[player] then tracers[player] = CreateTracer() end
                local tracer = tracers[player]
                tracer.Visible = true
                -- Линия идет от центра нижней части экрана к игроку
                tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                tracer.To = Vector2.new(pos.X, pos.Y)
            else
                if tracers[player] then tracers[player].Visible = false end
            end
            
            -- Логика Дистанции (Обновление имен в Highlight если нужно)
            if getgenv().SuiteConfig.Visuals.Names and player.Character:FindFirstChild("Youlter_ESP") then
