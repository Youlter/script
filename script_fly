game:GetService("RunService").Heartbeat:Connect(function()
    if State.Fly and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        local HRP = LP.Character.HumanoidRootPart
        local Cam = workspace.CurrentCamera
        
        LP.Character.Humanoid.PlatformStand = true
        
        if not bG then bG = Instance.new("BodyGyro", HRP) bG.maxTorque = Vector3.new(9e9,9e9,9e9) bG.P = 9e4 end
        if not bV then bV = Instance.new("BodyVelocity", HRP) bV.maxForce = Vector3.new(9e9,9e9,9e9) end
        
        bG.cframe = Cam.CFrame
        local dir = Vector3.new(0,0,0)
        local UIS = game:GetService("UserInputService")
        if UIS:IsKeyDown(Enum.KeyCode.W) then dir = dir + Cam.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then dir = dir - Cam.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then dir = dir - Cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then dir = dir + Cam.CFrame.RightVector end
        
        bV.velocity = dir.Unit.Magnitude > 0 and dir.Unit * State.FlySpeed or Vector3.new(0,0.1,0)
    end
end)
