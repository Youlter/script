local oldKick
oldKick = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if self == LP and (method == "Kick" or method == "kick") then
        Rayfield:Notify({
            Title = "🚫 KICK ATTEMPTED",
            Content = "The server tried to kick you. Message: " .. tostring(...),
            Duration = 20
        })
        return nil -- Блокируем попытку кика (работает только против слабых античитов)
    end
    return oldKick(self, ...)
end)

