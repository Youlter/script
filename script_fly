local function ToggleTimeStop()
    _G.Settings.Visuals.TimeStop = not _G.Settings.Visuals.TimeStop
    if _G.Settings.Visuals.TimeStop then
        CurrentTimeValue = Services.Lighting.ClockTime
        Services.Lighting:SetMinutesAfterMidnight(CurrentTimeValue * 60)
        task.spawn(function()
            while _G.Settings.Visuals.TimeStop do
                Services.Lighting:SetMinutesAfterMidnight(CurrentTimeValue * 60)
                task.wait(0.1)
            end
        end)
    end
end

local function DestroyEverything()
    for _, conn in pairs(Connections) do
        if conn and conn.Disconnect then pcall(function() conn:Disconnect() end) end
    end
    ClearAllDrawings()
    if FlyObjects.BodyVelocity then FlyObjects.BodyVelocity:Destroy() end
    if FlyObjects.BodyGyro then FlyObjects.BodyGyro:Destroy() end
    if FlyObjects.BodyPosition then FlyObjects.BodyPosition:Destroy() end
    if Rayfield and Rayfield.Destroy then pcall(function() Rayfield:Destroy() end) end
    _G.Settings = nil
    for k, v in pairs(getfenv()) do
        if type(v) == "function" and string.find(tostring(k), "ESP") then
            setfenv(k, nil)
        end
    end
    Services.RunService:Stop()
end

