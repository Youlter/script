local function DrawBoxESP(drawings, hrp, head, dist, pos, onScreen, headOnScreen)
    if not onScreen then return end
    local size = 3 / pos.Z * 2.5
    local boxHeight = 4.5 * size
    local boxWidth = 2.8 * size
    local top = pos.Y - boxHeight / 2
    local left = pos.X - boxWidth / 2
    
    drawings.Box.Visible = true
    drawings.Box.Size = Vector2.new(boxWidth * 100, boxHeight * 100)
    drawings.Box.Position = Vector2.new(left * 100, top * 100)
    drawings.Box.Color = _G.Settings.Visuals.ESP.BoxColor
    drawings.Box.Thickness = _G.Settings.Visuals.ESP.Thickness
    drawings.Box.Transparency = _G.Settings.Visuals.ESP.Transparency
end

local function DrawTracersESP(drawings, pos, viewport)
    drawings.Tracer.Visible = true
    drawings.Tracer.From = Vector2.new(viewport.X / 2, viewport.Y)
    drawings.Tracer.To = Vector2.new(pos.X, pos.Y)
    drawings.Tracer.Color = _G.Settings.Visuals.ESP.TracerColor
    drawings.Tracer.Thickness = _G.Settings.Visuals.ESP.Thickness
    drawings.Tracer.Transparency = _G.Settings.Visuals.ESP.Transparency
end

local function DrawHeadCircleESP(drawings, headPos, boxWidth)
    drawings.Circle.Visible = true
    drawings.Circle.Position = Vector2.new(headPos.X, headPos.Y)
    drawings.Circle.Radius = boxWidth * 12
    drawings.Circle.Color = _G.Settings.Visuals.ESP.HeadColor
    drawings.Circle.Thickness = 2
    drawings.Circle.Transparency = _G.Settings.Visuals.ESP.Transparency
    drawings.Circle.Filled = false
    drawings.Circle.NumSides = 80
end

local function DrawSkeletonESP(drawings, character, camera)
    local parts = {"Head", "UpperTorso", "LowerTorso", "LeftUpperArm", "RightUpperArm", "LeftLowerArm", "RightLowerArm"}
    local positions = {}
    for _, partName in pairs(parts) do
        local part = character:FindFirstChild(partName)
        if part then
            local pos, onScreen = camera:WorldToViewportPoint(part.Position)
            if onScreen then
                positions[partName] = Vector2.new(pos.X, pos.Y)
            end
        end
    end
    drawings.Skeleton.Visible = true
    if positions.Head and positions.UpperTorso then
        drawings.Skeleton.From = positions.Head
        drawings.Skeleton.To = positions.UpperTorso
        drawings.Skeleton.Color = _G.Settings.Visuals.ESP.SkeletonColor
    end
end

local function DrawHealthBarESP(drawings, humanoid, left, top, boxWidth)
    local healthPercent = humanoid.Health / humanoid.MaxHealth
    drawings.HealthBar.Visible = true
    drawings.HealthBar.Size = Vector2.new(boxWidth * 100 * healthPercent, 4)
    drawings.HealthBar.Position = Vector2.new(left * 100, (top - 8) * 100)
    drawings.HealthBar.Color = Color3.fromRGB(255 - (255 * (1 - healthPercent)), 255 * healthPercent, 0)
    drawings.HealthBar.Thickness = 1
    drawings.HealthBar.Transparency = 0.5
    drawings.HealthBar.Filled = true
end

local function DrawNameTagESP(drawings, player, pos, top)
    drawings.NameTag.Visible = true
    drawings.NameTag.Position = Vector2.new(pos.X, top - 18)
    drawings.NameTag.Text = player.Name
    drawings.NameTag.Size = 14
    drawings.NameTag.Center = true
    drawings.NameTag.Color = _G.Settings.Visuals.ESP.NameColor
    drawings.NameTag.Transparency = _G.Settings.Visuals.ESP.Transparency
end

local function DrawDistanceESP(drawings, pos, dist)
    drawings.DistanceText.Visible = true
    drawings.DistanceText.Position = Vector2.new(pos.X, pos.Y + 30)
    drawings.DistanceText.Text = math.floor(dist) .. "m"
    drawings.DistanceText.Size = 10
    drawings.DistanceText.Center = true
    drawings.DistanceText.Color = _G.Settings.Visuals.ESP.NameColor
    drawings.DistanceText.Transparency = _G.Settings.Visuals.ESP.Transparency
end

local function ClearAllDrawings()
    for player, drawings in pairs(DrawingObjects) do
        if drawings then
            if drawings.Box then drawings.Box:Remove() end
            if drawings.Tracer then drawings.Tracer:Remove() end
            if drawings.Circle then drawings.Circle:Remove() end
            if drawings.Skeleton then drawings.Skeleton:Remove() end
            if drawings.HealthBar then drawings.HealthBar:Remove() end
            if drawings.NameTag then drawings.NameTag:Remove() end
            if drawings.DistanceText then drawings.DistanceText:Remove() end
        end
    end
    DrawingObjects = {}
end

local function CreateAllESP()
    ClearAllDrawings()
    for _, player in pairs(Services.Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local drawings = {}
            if _G.Settings.Visuals.ESP.Box then
                drawings.Box = Drawing.new("Square")
                drawings.Box.Thickness = _G.Settings.Visuals.ESP.Thickness
                drawings.Box.Transparency = _G.Settings.Visuals.ESP.Transparency
                drawings.Box.Filled = false
            end
            if _G.Settings.Visuals.ESP.Tracers then
                drawings.Tracer = Drawing.new("Line")
                drawings.Tracer.Thickness = _G.Settings.Visuals.ESP.Thickness
                drawings.Tracer.Transparency = _G.Settings.Visuals.ESP.Transparency
            end
            if _G.Settings.Visuals.ESP.HeadCircle then
                drawings.Circle = Drawing.new("Circle")
                drawings.Circle.Thickness = 2
                drawings.Circle.Transparency = _G.Settings.Visuals.ESP.Transparency
                drawings.Circle.Filled = false
            end
            if _G.Settings.Visuals.ESP.Skeleton then
                drawings.Skeleton = Drawing.new("Line")
                drawings.Skeleton.Thickness = 2
                drawings.Skeleton.Transparency = _G.Settings.Visuals.ESP.Transparency
            end
            if _G.Settings.Visuals.ESP.HealthBar then
                drawings.HealthBar = Drawing.new("Square")
                drawings.HealthBar.Thickness = 1
                drawings.HealthBar.Transparency = 0.5
                drawings.HealthBar.Filled = true
            end
            if _G.Settings.Visuals.ESP.NameTag then
                drawings.NameTag = Drawing.new("Text")
                drawings.NameTag.Size = 14
                drawings.NameTag.Center = true
                drawings.NameTag.Transparency = _G.Settings.Visuals.ESP.Transparency
            end
            if _G.Settings.Visuals.ESP.Distance then
                drawings.DistanceText = Drawing.new("Text")
                drawings.DistanceText.Size = 10
                drawings.DistanceText.Center = true
                drawings.DistanceText.Transparency = _G.Settings.Visuals.ESP.Transparency
            end
            DrawingObjects[player] = drawings
        end
    end
end

local function UpdateAllESP()
    ESPUpdateCounter = ESPUpdateCounter + 1
    if ESPUpdateCounter < 3 then return end
    ESPUpdateCounter = 0
    
    if not Camera then return end
    local viewport = Camera.ViewportSize
    
    for player, drawings in pairs(DrawingObjects) do
        local character = player and player.Character
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        local head = character and character:FindFirstChild("Head")
        local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
        
        if hrp and head and humanoid and humanoid.Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            local headPos, headOnScreen = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.4, 0))
            local dist = PlayerData.RootPart and (hrp.Position - PlayerData.RootPart.Position).Magnitude or 0
            
            if dist <= _G.Settings.Visuals.ESP.MaxDistance and (onScreen or headOnScreen) then
                local size = 3 / pos.Z * 2.5
                local boxHeight = 4.5 * size
                local boxWidth = 2.8 * size
                local top = pos.Y - boxHeight / 2
                local left = pos.X - boxWidth / 2
                
                if drawings.Box and _G.Settings.Visuals.ESP.Box then
                    DrawBoxESP(drawings, hrp, head, dist, pos, onScreen, headOnScreen)
                elseif drawings.Box then drawings.Box.Visible = false end
                
                if drawings.Tracer and _G.Settings.Visuals.ESP.Tracers then
                    DrawTracersESP(drawings, pos, viewport)
                elseif drawings.Tracer then drawings.Tracer.Visible = false end
                
                if drawings.Circle and _G.Settings.Visuals.ESP.HeadCircle and headOnScreen then
                    DrawHeadCircleESP(drawings, headPos, boxWidth)
                elseif drawings.Circle then drawings.Circle.Visible = false end
                
                if drawings.Skeleton and _G.Settings.Visuals.ESP.Skeleton then
                    DrawSkeletonESP(drawings, character, Camera)
                elseif drawings.Skeleton then drawings.Skeleton.Visible = false end
                
                if drawings.HealthBar and _G.Settings.Visuals.ESP.HealthBar then
                    DrawHealthBarESP(drawings, humanoid, left, top, boxWidth)
                elseif drawings.HealthBar then drawings.HealthBar.Visible = false end
                
                if drawings.NameTag and _G.Settings.Visuals.ESP.NameTag then
                    DrawNameTagESP(drawings, player, pos, top)
                elseif drawings.NameTag then drawings.NameTag.Visible = false end
                
                if drawings.DistanceText and _G.Settings.Visuals.ESP.Distance then
                    DrawDistanceESP(drawings, pos, dist)
                elseif drawings.DistanceText then drawings.DistanceText.Visible = false end
            else
                if drawings.Box then drawings.Box.Visible = false end
                if drawings.Tracer then drawings.Tracer.Visible = false end
                if drawings.Circle then drawings.Circle.Visible = false end
                if drawings.Skeleton then drawings.Skeleton.Visible = false end
                if drawings.HealthBar then drawings.HealthBar.Visible = false end
                if drawings.NameTag then drawings.NameTag.Visible = false end
                if drawings.DistanceText then drawings.DistanceText.Visible = false end
            end
        else
            if drawings.Box then drawings.Box.Visible = false end
            if drawings.Tracer then drawings.Tracer.Visible = false end
            if drawings.Circle then drawings.Circle.Visible = false end
            if drawings.Skeleton then drawings.Skeleton.Visible = false end
            if drawings.HealthBar then drawings.HealthBar.Visible = false end
            if drawings.NameTag then drawings.NameTag.Visible = false end
            if drawings.DistanceText then drawings.DistanceText.Visible = false end
        end
    end
end

