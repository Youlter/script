local function LedgeGrab()
    if not _G.Settings.Movement.LedgeGrab or not ValidateCharacter() then return end
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {PlayerData.Character}
    local forwardRay = Services.Workspace:Raycast(PlayerData.RootPart.Position, Camera.CFrame.LookVector * 5, raycastParams)
    if forwardRay and not PlayerData.Humanoid.FloorMaterial then
        PlayerData.Humanoid.PlatformStand = true
        PlayerData.RootPart.Anchored = true
        task.wait(0.5)
        PlayerData.RootPart.Anchored = false
        PlayerData.Humanoid.PlatformStand = false
        PlayerData.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end

local function WallRun()
    if not _G.Settings.Movement.WallRun or not ValidateCharacter() then return end
    local rightRay = Services.Workspace:Raycast(PlayerData.RootPart.Position, Camera.CFrame.RightVector * 3)
    local leftRay = Services.Workspace:Raycast(PlayerData.RootPart.Position, -Camera.CFrame.RightVector * 3)
    if (rightRay or leftRay) and not PlayerData.Humanoid.FloorMaterial and PlayerData.Humanoid.MoveDirection.Magnitude > 0 then
        PlayerData.Humanoid.PlatformStand = true
        local direction = rightRay and Camera.CFrame.RightVector or -Camera.CFrame.RightVector
        PlayerData.RootPart.Velocity = direction * 50 + Vector3.new(0, 5, 0)
        task.wait(0.2)
        PlayerData.Humanoid.PlatformStand = false
    end
end

