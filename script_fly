-- // [UTILITY: ESP BUILDER]
local function CreateESP(player)
    local highlight = Instance.new("Highlight")
    highlight.Name = "YoulterHighlight"
    highlight.Parent = player.Character
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.FillColor = getgenv().Config.Visuals.Color
    
    -- Трейсер (Линия до игрока)
    local tracer = Drawing.new("Line")
    tracer.Visible = false
    tracer.Color = getgenv().Config.Visuals.Color
    tracer.Thickness = 1.5

    local connection
    connection = RunService.RenderStepped:Connect(function()
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and getgenv().Config.Visuals.ESP then
            highlight.Enabled = true
            highlight.FillColor = getgenv().Config.Visuals.Color
            
            if getgenv().Config.Visuals.Tracers then
                local vector, onScreen = Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position)
                if onScreen then
                    tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y) -- Из центра низа
                    tracer.To = Vector2.new(vector.X, vector.Y)
                    tracer.Visible = true
                else
                    tracer.Visible = false
                end
            else
                tracer.Visible = false
            end
        else
            highlight.Enabled = false
            tracer.Visible = false
            if not player.Parent then
                tracer:Remove()
                highlight:Destroy()
                connection:Disconnect()
            end
        end
    end)
end

