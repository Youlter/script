local function AddESP(Player)
    -- Drawing API объекты (Работают как оверлей)
    local Box = Drawing.new("Square")
    local Tracer = Drawing.new("Line")
    local HealthBar = Drawing.new("Line")
    local NameTag = Drawing.new("Text")

    Box.Thickness = 1
    Box.Filled = false
    Tracer.Thickness = 1
    NameTag.Size = 14
    NameTag.Center = true
    NameTag.Outline = true

    local function Update()
        local Connection
        Connection = RunService.RenderStepped:Connect(function()
            if getgenv().SuiteConfig.Visuals.Enabled and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                local HRP = Player.Character.HumanoidRootPart
                local Hum = Player.Character:FindFirstChild("Humanoid")
                local Pos, OnScreen = Camera:WorldToViewportPoint(HRP.Position)
                
                if OnScreen and Hum and Hum.Health > 0 then
                    -- Расчет размеров на основе дистанции (IY Математика)
                    local SizeY = (Camera:WorldToViewportPoint(HRP.Position + Vector3.new(0, 3, 0)).Y - Camera:WorldToViewportPoint(HRP.Position - Vector3.new(0, 3, 0)).Y)
                    local SizeX = SizeY / 1.5
                    local TopLeft = Vector2.new(Pos.X - SizeX / 2, Pos.Y - SizeY / 2)

                    -- Отрисовка Коробки
                    if getgenv().SuiteConfig.Visuals.Boxes then
                        Box.Size = Vector2.new(SizeX, SizeY)
                        Box.Position = TopLeft
                        Box.Color = getgenv().SuiteConfig.Visuals.BoxColor
                        Box.Visible = true
                    else Box.Visible = false end

                    -- Отрисовка Трейсеров
                    if getgenv().SuiteConfig.Visuals.Tracers then
                        Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        Tracer.To = Vector2.new(Pos.X, Pos.Y + (SizeY / 2))
                        Tracer.Color = Color3.new(1, 1, 1)
                        Tracer.Visible = true
                    else Tracer.Visible = false end
                else
                    Box.Visible = false; Tracer.Visible = false
                end
            else
                Box.Visible = false; Tracer.Visible = false
                if not Player.Parent then
                    Box:Remove(); Tracer:Remove(); Connection:Disconnect()
                end
            end
        end)
    end
    coroutine.wrap(Update)()
end

