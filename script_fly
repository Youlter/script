                    Root.RotVelocity = Vector3.new(0, 999999, 0)
                    
                    -- Агрессивный телепорт в центр цели
                    Root.CFrame = VRoot.CFrame * CFrame.Angles(math.rad(math.random(0,360)), math.rad(math.random(0,360)), 0)
                    
                    -- Если цель улетела (проверка дистанции)
                    if (VRoot.Position - Root.Position).Magnitude > 250 then
                        FlingLoop:Disconnect()
                    end
