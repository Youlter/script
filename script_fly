-- Функция поиска ближайшей цели (Чистая логика IY)
local function GetClosestPlayer()
    local Target = nil
    local Dist = getgenv().SuiteConfig.Combat.FieldOfView

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LP and v.Character and v.Character:FindFirstChild(getgenv().SuiteConfig.Combat.TargetPart) then
            if getgenv().SuiteConfig.Visuals.TeamCheck and v.Team == LP.Team then continue end
            
            local Pos, OnScreen = Camera:WorldToViewportPoint(v.Character[getgenv().SuiteConfig.Combat.TargetPart].Position)
            local Magnitude = (Vector2.new(Pos.X, Pos.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude

            if OnScreen and Magnitude < Dist then
                if getgenv().SuiteConfig.Combat.WallCheck then
                    local Parts = Camera:GetPartsObscuringTarget({v.Character[getgenv().SuiteConfig.Combat.TargetPart].Position}, {LP.Character, v.Character})
                    if #Parts > 0 then continue end
                end
                Dist = Magnitude
                Target = v
            end
        end
    end
    return Target
end

