local function SaveConfigToJson()
    local configData = {
        Settings = _G.Settings,
        Version = "2.0.0",
        Created = os.date("%Y-%m-%d %H:%M:%S")
    }
    local encoded = game:GetService("HttpService"):JSONEncode(configData)
    local file = writefile and writefile("Youlter_Config.json", encoded)
    if file then
        return true
    end
    return false
end

local function LoadConfigFromJson()
    local file = readfile and readfile("Youlter_Config.json")
    if file then
        local success, decoded = pcall(function()
            return game:GetService("HttpService"):JSONDecode(file)
        end)
        if success and decoded and decoded.Settings then
            _G.Settings = decoded.Settings
            return true
        end
    end
    return false
end

