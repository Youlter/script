-- 1.2: Продвинутый загрузчик (Анти-SSL Fail)
local function SecureLoad(url)
    local success, content = pcall(function()
        -- Используем параметр true для обхода кэша Potassium
        return game:HttpGet(url, true)
    end)
    
    if not success or not content or #content < 1000 then
        -- Резервный метод через прокси, если основной упал
        warn("Main source failed, trying mirror...")
        local proxyUrl = "https://api.allorigins.win/raw?url=" .. url
        success, content = pcall(function() return game:HttpGet(proxyUrl) end)
    end
    
    return success and content or nil
end

-- 1.3: Инициализация Rayfield (ОБНОВЛЕННАЯ ССЫЛКА)
local libSource = SecureLoad("https://sirius.menu/rayfield")

if not libSource or #libSource < 100 then
    -- Если основной сайт лежит, используем проверенное зеркало
    libSource = SecureLoad("https://raw.githubusercontent.com/shlexware/Rayfield/main/source.lua")
end

if libSource then
    local success, result = pcall(function()
        return loadstring(libSource)()
    end)
    
    if success then
        Rayfield = result
    else
        warn("Ошибка компиляции: " .. tostring(result))
    end
else
    return error("КРИТИЧЕСКАЯ ОШИБКА: Библиотека Rayfield недоступна по всем ссылкам!")
end
