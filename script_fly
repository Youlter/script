local function UpdatePlayerData()
    local success = pcall(function()
        PlayerData.Character = LocalPlayer.Character
        if PlayerData.Character then
            PlayerData.Humanoid = PlayerData.Character:FindFirstChildWhichIsA("Humanoid")
            PlayerData.RootPart = PlayerData.Character:FindFirstChild("HumanoidRootPart")
        end
        Camera = Services.Workspace.CurrentCamera
    end)
    if not success then
        PlayerData.Character = nil
        PlayerData.Humanoid = nil
        PlayerData.RootPart = nil
    end
end

local function ValidateCharacter()
    if not PlayerData.Character or not PlayerData.Character.Parent then
        UpdatePlayerData()
        return false
    end
    if not PlayerData.Humanoid or PlayerData.Humanoid.Health <= 0 then
        return false
    end
    if not PlayerData.RootPart then
        return false
    end
    return true
end

local function CreateFlySystem()
    if not ValidateCharacter() then return end
    if FlyObjects.BodyVelocity then FlyObjects.BodyVelocity:Destroy() end
    if FlyObjects.BodyGyro then FlyObjects.BodyGyro:Destroy() end
    if FlyObjects.BodyPosition then FlyObjects.BodyPosition:Destroy() end
    
    if _G.Settings.Movement.Fly.Mode == "Velocity" then
        FlyObjects.BodyVelocity = Instance.new("BodyVelocity")
        FlyObjects.BodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        FlyObjects.BodyVelocity.P = 1e5
        FlyObjects.BodyVelocity.Parent = PlayerData.RootPart
        
        FlyObjects.BodyGyro = Instance.new("BodyGyro")
        FlyObjects.BodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        FlyObjects.BodyGyro.P = 1e5
        FlyObjects.BodyGyro.D = 1000
        FlyObjects.BodyGyro.Parent = PlayerData.RootPart
    else
        FlyObjects.BodyPosition = Instance.new("BodyPosition")
        FlyObjects.BodyPosition.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        FlyObjects.BodyPosition.P = 1e5
        FlyObjects.BodyPosition.D = 1000
        FlyObjects.BodyPosition.Parent = PlayerData.RootPart
    end
    PlayerData.Humanoid.PlatformStand = true
end

local function UpdateFly()
    if not _G.Settings.Movement.Fly.Active or not ValidateCharacter() then return end
    
    if _G.Settings.Movement.Fly.Mode == "Velocity" and FlyObjects.BodyVelocity and FlyObjects.BodyGyro then
        local forward = Camera.CFrame.LookVector
        local right = Camera.CFrame.RightVector
        local up = Vector3.new(0,1,0)
        local velocity = Vector3.new()
        if FlyState.Forward then velocity = velocity + forward end
        if FlyState.Backward then velocity = velocity - forward end
        if FlyState.Right then velocity = velocity + right end
        if FlyState.Left then velocity = velocity - right end
        if FlyState.Up then velocity = velocity + up end
        if FlyState.Down then velocity = velocity - up end
        if velocity.Magnitude > 0 then
            velocity = velocity.Unit * _G.Settings.Movement.Fly.Speed
        end
        local vertVelocity = 0
        if FlyState.Up then vertVelocity = _G.Settings.Movement.Fly.VerticalSpeed
        elseif FlyState.Down then vertVelocity = -_G.Settings.Movement.Fly.VerticalSpeed end
        velocity = velocity + Vector3.new(0, vertVelocity, 0)
        FlyObjects.BodyVelocity.Velocity = velocity
        FlyObjects.BodyGyro.CFrame = Camera.CFrame
    elseif _G.Settings.Movement.Fly.Mode == "CFrame" and FlyObjects.BodyPosition then
        local moveVector = Vector3.new()
        if FlyState.Forward then moveVector = moveVector + Vector3.new(0,0,-1) end
        if FlyState.Backward then moveVector = moveVector + Vector3.new(0,0,1) end
        if FlyState.Right then moveVector = moveVector + Vector3.new(1,0,0) end
        if FlyState.Left then moveVector = moveVector + Vector3.new(-1,0,0) end
        if FlyState.Up then moveVector = moveVector + Vector3.new(0,1,0) end
        if FlyState.Down then moveVector = moveVector + Vector3.new(0,-1,0) end
        if moveVector.Magnitude > 0 then
            moveVector = moveVector.Unit * _G.Settings.Movement.Fly.Speed
        end
        local delta = Services.RunService.Heartbeat:Wait()
        local newPos = PlayerData.RootPart.Position + (Camera.CFrame:VectorToWorldSpace(moveVector) * delta)
        FlyObjects.BodyPosition.Position = newPos
    end
end

local function UpdateNoClip()
    if not _G.Settings.Movement.NoClip or not ValidateCharacter() then return end
    for _, descendant in pairs(PlayerData.Character:GetDescendants()) do
        if descendant:IsA("BasePart") then
            pcall(function() descendant.CanCollide = false end)
        end
    end
end

local function ToggleNoClip()
    _G.Settings.Movement.NoClip = not _G.Settings.Movement.NoClip
    if not _G.Settings.Movement.NoClip and ValidateCharacter() then
        for _, descendant in pairs(PlayerData.Character:GetDescendants()) do
            if descendant:IsA("BasePart") and descendant.Name ~= "HumanoidRootPart" then
                pcall(function() descendant.CanCollide = true end)
            end
        end
    end
end

local function UpdateMovement()
    if not ValidateCharacter() then return end
    if PlayerData.Humanoid.WalkSpeed ~= _G.Settings.Movement.WalkSpeed then
        PlayerData.Humanoid.WalkSpeed = _G.Settings.Movement.WalkSpeed
    end
    if PlayerData.Humanoid.JumpPower ~= _G.Settings.Movement.JumpPower then
        PlayerData.Humanoid.JumpPower = _G.Settings.Movement.JumpPower
    end
    if _G.Settings.Movement.SpinBot.Active and PlayerData.RootPart then
        FlyState.Spin = FlyState.Spin + _G.Settings.Movement.SpinBot.Speed * Services.RunService.Heartbeat:Wait()
        local newCFrame = PlayerData.RootPart.CFrame * CFrame.Angles(0, math.rad(FlyState.Spin), 0)
        PlayerData.RootPart.CFrame = newCFrame
    end
end

local function InfiniteJump(Input, GameProcessed)
    if GameProcessed then return end
    if _G.Settings.Movement.InfiniteJump and Input.KeyCode == Enum.KeyCode.Space and ValidateCharacter() and PlayerData.Humanoid then
        PlayerData.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        task.wait(0.05)
        PlayerData.Humanoid:ChangeState(Enum.HumanoidStateType.Running)
    end
end

local function AntiFling()
    if not _G.Settings.Movement.AntiFling or not ValidateCharacter() then return end
    if PlayerData.RootPart.Velocity.Y < -150 or PlayerData.RootPart.Velocity.Magnitude > 600 then
        PlayerData.RootPart.Velocity = Vector3.new(0, 0, 0)
        PlayerData.RootPart.CFrame = PlayerData.RootPart.CFrame + Vector3.new(0, 15, 0)
    end
end

local function AutoClicker()
