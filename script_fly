local MobArenaSystem = {
    Enabled = false,
    Mobs = {},
    AutoAttack = false,
    AttackRange = 15,
    DamageMultiplier = 1
}

function MobArenaSystem:ScanMobs()
    if not self.Enabled then return end
    self.Mobs = {}
    for _, obj in pairs(Services.Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
            if obj ~= PlayerData.Character then
                table.insert(self.Mobs, obj)
            end
        end
    end
end

function MobArenaSystem:AttackNearest()
    if not self.AutoAttack or not ValidateCharacter() then return end
    local closest = nil
    local shortestDist = self.AttackRange
    for _, mob in pairs(self.Mobs) do
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        if hrp then
            local dist = (hrp.Position - PlayerData.RootPart.Position).Magnitude
            if dist < shortestDist then
                shortestDist = dist
                closest = mob
            end
        end
    end
    if closest then
        local humanoid = closest:FindFirstChildWhichIsA("Humanoid")
        if humanoid and humanoid.Health > 0 then
            humanoid.Health = humanoid.Health - (10 * self.DamageMultiplier)
            PlayerData.Humanoid:MoveTo(closest.HumanoidRootPart.Position)
        end
    end
end

