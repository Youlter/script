FixTab:CreateButton({
    Name = "Hook Remote Security (Universal)",
    Callback = function()
        local g = getgenv()
        local raw = getrawmetatable(game)
        setreadonly(raw, false)
        local oldNamecall = raw.__namecall

        raw.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            
            -- Блокируем передачу инфы о скорости и прыжках
            if method == "FireServer" and (tostring(self):lower():find("kick") or tostring(self):lower():find("check") or tostring(self):lower():find("ban")) then
                warn("Blocked attempt to call security remote: " .. tostring(self))
                return nil
            end
            return oldNamecall(self, ...)
        end)
        setreadonly(raw, true)
        SendNotify("Remote Hook Active.")
    end
})

