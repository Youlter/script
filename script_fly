local function AddESP(Player)
    local Box = Drawing.new("Square")
    local Tracer = Drawing.new("Line")
    local HealthBar = Drawing.new("Line")
    local HealthBarOutline = Drawing.new("Line")
    local Info = Drawing.new("Text")

    Box.Thickness = 1
    Box.Filled = false
    Tracer.Thickness = 1
    HealthBar.Thickness = 2
    HealthBarOutline.Thickness = 3
    Info.Size = 16
    Info.Center = true
    Info.Outline = true

    local function Updater()
        local Connection
        Connection = RunService.RenderStepped:Connect(function()
            if getgenv().SuiteConfig.Visuals.Enabled and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") and Player.Character:FindFirstChild("Humanoid") then
                local HRP = Player.Character.HumanoidRootPart
                local Hum = Player.Character.Humanoid
                local Pos, OnScreen = Camera:WorldToViewportPoint(HRP.Position)
                local IsTeammate = getgenv().SuiteConfig.Visuals.TeamCheck and Player.Team == LP.Team
                
                if OnScreen and not IsTeammate and Hum.Health > 0 then
                    local Size = Vector2.new(2000 / Pos.Z, 3000 / Pos.Z)
                    local TopLeft = Vector2.new(Pos.X - Size.X / 2, Pos.Y - Size.Y / 2)

                    if getgenv().SuiteConfig.Visuals.Boxes then
                        Box.Size = Size
                        Box.Position = TopLeft
                        Box.Color = getgenv().SuiteConfig.Visuals.BoxColor
                        Box.Visible = true
                    else Box.Visible = false end

                    if getgenv().SuiteConfig.Visuals.Tracers then
                        Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        Tracer.To = Vector2.new(Pos.X, Pos.Y + (Size.Y / 2))
                        Tracer.Color = Color3.new(1, 1, 1)
                        Tracer.Visible = true
                    else Tracer.Visible = false end

                    if getgenv().SuiteConfig.Visuals.Health then
                        local HealthPercent = Hum.Health / Hum.MaxHealth
                        HealthBarOutline.From = Vector2.new(TopLeft.X - 5, TopLeft.Y + Size.Y)
                        HealthBarOutline.To = Vector2.new(TopLeft.X - 5, TopLeft.Y)
                        HealthBarOutline.Color = Color3.new(0, 0, 0)
                        HealthBarOutline.Visible = true
                        HealthBar.From = Vector2.new(TopLeft.X - 5, TopLeft.Y + Size.Y)
                        HealthBar.To = Vector2.new(TopLeft.X - 5, (TopLeft.Y + Size.Y) - (Size.Y * HealthPercent))
                        HealthBar.Color = Color3.new(1, 0, 0):Lerp(Color3.new(0, 1, 0), HealthPercent)
                        HealthBar.Visible = true
                    else
                        HealthBar.Visible = false
                        HealthBarOutline.Visible = false
                    end

                    if getgenv().SuiteConfig.Visuals.Names then
                        Info.Text = string.format("%s [%d]", Player.Name, math.floor(Pos.Z))
                        Info.Position = Vector2.new(Pos.X, TopLeft.Y - 20)
                        Info.Visible = true
                    else Info.Visible = false end
                else
                    Box.Visible = false; Tracer.Visible = false; HealthBar.Visible = false; HealthBarOutline.Visible = false; Info.Visible = false
                end
            else
                Box.Visible = false; Tracer.Visible = false; HealthBar.Visible = false; HealthBarOutline.Visible = false; Info.Visible = false
                if not Player.Parent then
                    Box:Remove(); Tracer:Remove(); HealthBar:Remove(); HealthBarOutline:Remove(); Info:Remove()
                    Connection:Disconnect()
                end
            end
        end)
    end
    coroutine.wrap(Updater)()
end

